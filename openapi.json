{
  "openapi": "3.0.3",
  "info": {
    "title": "BOIFiler API",
    "description": "Beneficial Ownership Information filing",
    "version": "1.0.0",
    "x-category": "Financial",
    "x-long-description": "The BOIFiler API provides production-ready beneficial ownership information filing. Fully compatible with RapidAPI marketplace, ready for monetization.",
    "x-badges": [
      {
        "name": "production-ready",
        "color": "green"
      },
      {
        "name": "finance",
        "color": "blue"
      }
    ]
  },
  "servers": [
    {
      "url": "https://boifiler-api-production.up.railway.app",
      "description": "Production"
    }
  ],
  "paths": {
    "/v1/entity/search": {
      "get": {
        "summary": "Search entities",
        "operationId": "v1_entity_search",
        "parameters": [
          {
            "name": "x-api-key",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API key for authentication"
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        }
      }
    },
    "/v1/entity/{ein}": {
      "get": {
        "summary": "Get entity details",
        "operationId": "v1_entity_ein",
        "parameters": [
          {
            "name": "ein",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "x-api-key",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API key for authentication"
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        }
      }
    },
